te=\"20200619\"; 当前交易日的数据需要交易所收盘后统计\n\n输出参数\n\n名称\n类型\n描述\n\n证券类别\nobject\n-\n\n数量\nint64\n注意单位: 只\n\n成交金额\nfloat64\n注意单位: 元\n\n总市值\nfloat64\n-\n\n流通市值\nfloat64\n-\n\n接口示例\n\nimport akshare as ak\n\nstock_szse_summary_df = ak.stock_szse_summary(date=\"20200\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"ffe1ae7a3567a54c\">>>","warning":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"20264cd72ed239c0\">>>\nSource: Web Fetch\n---\nResponse body truncated after 2000000 bytes.\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"20264cd72ed239c0\">>>"},"isError":false,"timestamp":1772155231654}}
