{"type":"message","id":"ee6c0174","parentId":"dd873dd3","timestamp":"2026-02-26T07:35:36.788Z","message":{"role":"assistant","content":[{"type":"text","text":"好主意！让我修改 `ddg` 的 MCP 服务器，添加百度和搜狗作为国内搜索源，并设置优先调用。\n\n首先看看现有的 MCP 服务器代码："},{"type":"toolCall","id":"functions.read:99","name":"read","arguments":{"file_path":"D:\\gooddog\\scripts\\mcp_ddgs_server.py"}}],"api":"openai-completions","provider":"bailian","model":"kimi-k2.5","usage":{"input":71119,"output":65,"cacheRead":0,"cacheWrite":0,"totalTokens":71184,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772091277671}}
{"type":"message","id":"1b109a11","parentId":"ee6c0174","timestamp":"2026-02-26T07:35:36.805Z","message":{"role":"toolResult","toolCallId":"functions.read:99","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\r\n\"\"\"\r\nMCP 服务器：多后端网页搜索（ddgs backend=auto + Bing 回退），供 OpenClaw/mcporter 调用。\r\n依赖: pip install mcp ddgs duckduckgo-search\r\n运行: python mcp_ddgs_server.py  （stdio，由 mcporter 启动）\r\n\"\"\"\r\nfrom __future__ import annotations\r\n\r\nimport sys\r\n\r\n\r\ndef _run_web_search(query: str, max_results: int = 10) -> list[dict]:\r\n    \"\"\"多后端搜索：优先 ddgs(backend=auto)，无结果时用 duckduckgo_search(backend=bing)。\"\"\"\r\n    results: list[dict] = []\r\n    # 1) 优先 ddgs（多引擎：bing/brave/google 等）\r\n    try:\r\n        from ddgs import DDGS\r\n        out = DDGS().text(query, max_results=max_results, backend=\"auto\")\r\n        results = list(out) if out else []\r\n    except ImportError:\r\n        try:\r\n            from duckduckgo_search import DDGS\r\n            ddgs = DDGS()\r\n            out = ddgs.text(query, max_results=max_results, backend=\"auto\")\r\n            results = list(out) if out else []\r\n        except ImportError:\r\n            raise ImportError(\"请安装: pip install ddgs 或 pip install duckduckgo-search\")\r\n    # 2) 仍无结果则用 bing 再试\r\n    if not results:\r\n        try:\r\n            from duckduckgo_search import DDGS\r\n            ddgs = DDGS()\r\n            out = ddgs.text(query, max_results=max_results, backend=\"bing\")\r\n            results = list(out) if out else []\r\n        except Exception:\r\n            pass\r\n    return results\r\n\r\n\r\ndef main() -> None:\r\n    from mcp.server.fastmcp import FastMCP\r\n\r\n    mcp = FastMCP(\"ddgs_search\")\r\n\r\n    @mcp.tool()\r\n    def web_search(query: str, max_results: int = 10) -> str:\r\n        \"\"\"搜索网页。使用多引擎（ddgs auto + Bing 回退），国内网络更稳定。\"\"\"\r\n        query = (query or \"\").strip()\r\n        if not query:\r\n            return \"Error: query 不能为空\"\r\n        max_results = min(max(max_results, 1), 20)\r\n        try:\r\n            results = _run_web_search(query, max_results)\r\n        except ImportError as e:\r\n            return f\"Error: {e}\\n请运行: pip install ddgs 或 pip install duckduckgo-search\"\r\n        except Exception as e:\r\n            return f\"Error: {e}\"\r\n        if not results:\r\n            return \"未找到结果，可换关键词或稍后重试。\"\r\n        lines = []\r\n        for i, r in enumerate(results, 1):\r\n            title = (r.get(\"title\") or \"\").strip()\r\n            href = (r.get(\"href\") or r.get(\"url\") or \"\").strip()\r\n            body = (r.get(\"body\") or \"\").strip()\r\n            lines.append(f\"{i}. {title}\\n   URL: {href}\\n   {body}\")\r\n        return \"\\n\\n\".join(lines)\r\n\r\n    # stdio 为默认，mcporter 会通过 stdin/stdout 通信\r\n    mcp.run()\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n    sys.exit(0)\r\n\r\n\r\n"}],"isError":false,"timestamp":1772091336799}}
{"type":"message","id":"cdb56f4b","parentId":"1b109a11","timestamp":"2026-02-26T07:41:32.177Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！现在我需要添加百度和搜狗搜索。让我修改这个文件："},{"type":"toolCall","id":"functions.write:100","name":"write","arguments":{"file_path":"D:\\gooddog\\scripts\\mcp_ddgs_server.py","content":"#!/usr/bin/env python3\n\"\"\"\nMCP 服务器：多后端网页搜索（百度/搜狗优先 + ddgs auto + Bing 回退），供 OpenClaw/mcporter 调用。\n依赖: pip install mcp ddgs duckduckgo-search requests beautifulsoup4\n运行: python mcp_ddgs_server.py  （stdio，由 mcporter 启动）\n\"\"\"\nfrom __future__ import annotations\n\nimport sys\nimport json\nimport urllib.request\nimport urllib.parse\nfrom typing import List, Dict, Optional\n\n\ndef _search_baidu(query: str, max_results: int = 10) -> List[Dict]:\n    \"\"\"百度搜索\"\"\"\n    results = []\n    try:\n        # URL 编码查询词\n        encoded_query = urllib.parse.quote(query)\n        url = f\"https://www.baidu.com/s?wd={encoded_query}&rn={max_results}\"\n        \n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36\",\n            \"Accept\": \"text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8\",\n            \"Accept-Language\": \"zh-CN,zh;q=0.9,en;q=0.8\",\n        }\n        \n        req = urllib.request.Request(url, headers=headers)\n        with urllib.request.urlopen(req, timeout=15) as response:\n            html = response.read().decode('utf-8', errors='ignore')\n            \n        # 解析搜索结果（简化版，基于常见百度HTML结构）\n        import re\n        \n        # 提取搜索结果区块\n        result_blocks = re.findall(r'<div[^>]*class=\"result\"[^>]*>(.*?)</div>\\s*</div>', html, re.DOTALL)\n        \n        for block in result_blocks[:max_results]:\n            # 提取标题和链接\n            title_match = re.search(r'<a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a>', block, re.DOTALL)\n            if title_match:\n                href = title_match.group(1)\n                title = re.sub(r'<[^>]+>', '', title_match.group(2)).strip()\n                \n                # 提取摘要\n                abstract_match = re.search(r'<span[^>]*class=\"content-right_[^\"]*\"[^>]*>(.*?)</span>', block, re.DOTALL)\n                if not abstract_match:\n                    abstract_match = re.search(r'<div[^>]*class=\"content-right_[^\"]*\"[^>]*>(.*?)</div>', block, re.DOTALL)\n                \n                body = \"\"\n                if abstract_match:\n                    body = re.sub(r'<[^>]+>', '', abstract_match.group(1)).strip()\n                \n                # 处理相对链接\n                if href.startswith('/'):\n                    href = 'https://www.baidu.com' + href\n                \n                results.append({\n                    \"title\": title,\n                    \"href\": href,\n                    \"body\": body[:200]  # 限制长度\n                })\n        \n        return results\n    except Exception as e:\n        print(f\"百度搜索出错: {e}\", file=sys.stderr)\n        return []\n\n\ndef _search_sogou(query: str, max_results: int = 10) -> List[Dict]:\n    \"\"\"搜狗搜索\"\"\"\n    results = []\n    try:\n        encoded_query = urllib.parse.quote(query)\n        url = f\"https://www.sogou.com/web?query={encoded_query}\"\n        \n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36\",\n            \"Accept\": \"text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8\",\n            \"Accept-Language\": \"zh-CN,zh;q=0.9\",\n        }\n        \n        req = urllib.request.Request(url, headers=headers)\n        with urllib.request.urlopen(req, timeout=15) as response:\n            html = response.read().decode('utf-8', errors='ignore')\n        \n        import re\n        \n        # 搜狗搜索结果解析\n        result_blocks = re.findall(r'<div class=\"vrwrap\"[^>]*>(.*?)</div>\\s*</div>', html, re.DOTALL)\n        \n        for block in result_blocks[:max_results]:\n            # 提取标题\n            title_match = re.search(r'<h3[^>]*><a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a></h3>', block, re.DOTALL)\n            if title_match:\n                href = title_match.group(1)\n                title = re.sub(r'<[^>]+>', '', title_match.group(2)).strip()\n                \n                # 提取摘要\n                abstract_match = re.search(r'<p class=\"str_info\"[^>]*>(.*?)</p>', block, re.DOTALL)\n                if not abstract_match:\n                    abstract_match = re.search(r'<div class=\"str-text\"[^>]*>(.*?)</div>', block, re.DOTALL)\n                \n                body = \"\"\n                if abstract_match:\n                    body = re.sub(r'<[^>]+>', '', abstract_match.group(1)).strip()\n                \n                results.append({\n                    \"title\": title,\n                    \"href\": href,\n                    \"body\": body[:200]\n                })\n        \n        return results\n    except Exception as e:\n        print(f\"搜狗搜索出错: {e}\", file=sys.stderr)\n        return []\n\n\ndef _run_web_search(query: str, max_results: int = 10) -> list[dict]:\n    \"\"\"多后端搜索：优先国内搜索引擎（百度/搜狗），失败时用 ddgs(backend=auto)，最后 Bing 回退。\"\"\"\n    results: list[dict] = []\n    \n    # 1) 优先百度（国内最稳定）\n    print(f\"尝试百度搜索: {query}\", file=sys.stderr)\n    results = _search_baidu(query, max_results)\n    if results:\n        print(f\"百度搜索成功，返回 {len(results)} 条结果\", file=sys.stderr)\n        return results\n    \n    # 2) 百度失败则用搜狗\n    print(f\"百度搜索失败，尝试搜狗搜索\", file=sys.stderr)\n    results = _search_sogou(query, max_results)\n    if results:\n        print(f\"搜狗搜索成功，返回 {len(results)} 条结果\", file=sys.stderr)\n        return results\n    \n    # 3) 国内引擎都失败，用 ddgs（多引擎：bing/brave/google 等）\n    print(f\"国内搜索引擎失败，尝试 ddgs\", file=sys.stderr)\n    try:\n        from ddgs import DDGS\n        out = DDGS().text(query, max_results=max_results, backend=\"auto\")\n        results = list(out) if out else []\n    except ImportError:\n        try:\n            from duckduckgo_search import DDGS\n            ddgs = DDGS()\n            out = ddgs.text(query, max_results=max_results, backend=\"auto\")\n            results = list(out) if out else []\n        except ImportError:\n            raise ImportError(\"请安装: pip install ddgs 或 pip install duckduckgo-search\")\n    \n    # 4) 仍无结果则用 bing 再试\n    if not results:\n        print(f\"ddgs 失败，尝试 Bing 回退\", file=sys.stderr)\n        try:\n            from duckduckgo_search import DDGS\n            ddgs = DDGS()\n            out = ddgs.text(query, max_results=max_results, backend=\"bing\")\n            results = list(out) if out else []\n        except Exception:\n            pass\n    \n    return results\n\n\ndef main() -> None:\n    from mcp.server.fastmcp import FastMCP\n\n    mcp = FastMCP(\"ddgs_search\")\n\n    @mcp.tool()\n    def web_search(query: str, max_results: int = 10) -> str:\n        \"\"\"搜索网页。优先使用国内搜索引擎（百度/搜狗），失败时用 ddgs auto + Bing 回退。\"\"\"\n        query = (query or \"\").strip()\n        if not query:\n            return \"Error: query 不能为空\"\n        max_results = min(max(max_results, 1), 20)\n        try:\n            results = _run_web_search(query, max_results)\n        except ImportError as e:\n            return f\"Error: {e}\\n请运行: pip install ddgs 或 pip install duckduckgo-search\"\n        except Exception as e:\n            return f\"Error: {e}\"\n        if not results:\n            return \"未找到结果，可换关键词或稍后重试。\"\n        lines = []\n        for i, r in enumerate(results, 1):\n            title = (r.get(\"title\") or \"\").strip()\n            href = (r.get(\"href\") or r.get(\"url\") or \"\").strip()\n            body = (r.get(\"body\") or \"\").strip()\n            lines.append(f\"{i}. {title}\\n   URL: {href}\\n   {body}\")\n        return \"\\n\\n\".join(lines)\n\n    # stdio 为默认，mcporter 会通过 stdin/stdout 通信\n    mcp.run()\n\n\nif __name__ == \"__main__\":\n    main()\n    sys.exit(0)\n"}}],"api":"openai-completions","provider":"bailian","model":"kimi-k2.5","usage":{"input":71898,"output":2288,"cacheRead":0,"cacheWrite":0,"totalTokens":74186,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772091336806}}
