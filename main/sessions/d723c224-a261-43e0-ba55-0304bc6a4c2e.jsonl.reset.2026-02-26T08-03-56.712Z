{"type":"message","id":"7e2a37a1","parentId":"7181fb9b","timestamp":"2026-02-26T03:34:11.447Z","message":{"role":"toolResult","toolCallId":"functions.read:32","toolName":"read","content":[{"type":"text","text":"# LLM clients\nanthropic>=0.34.0\nopenai>=1.54.0\n\n# Vector DB and search\nnumpy>=1.24.0\nchromadb>=0.4.0\n\n# Async and tools\naiofiles>=23.0.0\nwatchdog>=3.0.0\n\n# Utilities\npydantic>=2.0.0\npyyaml>=6.0.0\ntiktoken>=0.7.0\n\n# Database\naiosqlite>=0.19.0\n\n# Client Rich TUI\nrich>=13.0.0\n\n# Interactive select (/models arrow-key picker)\nquestionary>=2.0.0\n\n# Full-screen TUI (--tui mode, like openclaw pi-tui)\ntextual>=0.40.0\n\n# Web search (no API key required). Prefer ddgs (multi-backend); fallback: duckduckgo-search\nddgs>=9.0.0\nduckduckgo-search>=7.0.0\n\n"}],"isError":false,"timestamp":1772076851444}}
