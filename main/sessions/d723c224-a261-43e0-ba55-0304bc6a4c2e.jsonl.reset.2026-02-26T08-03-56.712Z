{"type":"message","id":"ab40ea34","parentId":"ce91e1fa","timestamp":"2026-02-26T03:32:27.910Z","message":{"role":"toolResult","toolCallId":"functions.read:30","toolName":"read","content":[{"type":"text","text":"\"\"\"工具注册表（支持按 profile/allow/deny 过滤）\"\"\"\nfrom typing import List, Dict, Optional, Set\nfrom .base import Tool\nfrom .tool_policy import resolve_allowed_tool_names, normalize_tool_name\n\n\nclass ToolRegistry:\n    \"\"\"工具注册表\"\"\"\n\n    def __init__(self):\n        self._tools: Dict[str, Tool] = {}\n\n    def register(self, tool: Tool):\n        \"\"\"注册工具\"\"\"\n        self._tools[normalize_tool_name(tool.name)] = tool\n\n    def unregister(self, name: str):\n        \"\"\"取消注册工具\"\"\"\n        n = normalize_tool_name(name)\n        if n in self._tools:\n            del self._tools[n]\n\n    def get_tool(self, name: str) -> Optional[Tool]:\n        \"\"\"获取工具\"\"\"\n        return self._tools.get(normalize_tool_name(name))\n\n    def _all_tool_names(self) -> List[str]:\n        return list(self._tools.keys())\n\n    def _filtered_tools(\n        self,\n        profile: Optional[str] = None,\n        allow: Optional[List[str]] = None,\n        deny: Optional[List[str]] = None,\n    ) -> List[Tool]:\n        all_names = self._all_tool_names()\n        allowed = resolve_allowed_tool_names(\n            profile=profile,\n            allow=allow,\n            deny=deny,\n            all_tool_names=all_names,\n        )\n        if allowed is None:\n            return list(self._tools.values())\n        return [t for n, t in self._tools.items() if n in allowed]\n\n    def get_tools(\n        self,\n        profile: Optional[str] = None,\n        allow: Optional[List[str]] = None,\n        deny: Optional[List[str]] = None,\n    ) -> List[Tool]:\n        \"\"\"获取工具列表；可按 profile/allow/deny 过滤。\"\"\"\n        if profile is None and allow is None and deny is None:\n            return list(self._tools.values())\n        return self._filtered_tools(profile=profile, allow=allow, deny=deny)\n\n    def get_tools_schema(\n        self,\n        profile: Optional[str] = None,\n        allow: Optional[List[str]] = None,\n        deny: Optional[List[str]] = None,\n    ) -> List[Dict]:\n        \"\"\"获取工具的 schema 列表（用于 LLM）；支持 profile/allow/deny 过滤。\"\"\"\n        tools = self.get_tools(profile=profile, allow=allow, deny=deny)\n        return [t.to_dict() for t in tools]\n\n"}],"isError":false,"timestamp":1772076747907}}
