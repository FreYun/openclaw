=3.4.0->paddlex[ocr-core]<3.5.0,>=3.4.0->paddleocr) (0.1.2)\r\nInstalling collected packages: python-bidi, py-cpuinfo, ujson, tzdata, shapely, safetensors, PyYAML, pypdfium2, pycryptodome, pyclipper, prettytable, Pillow, opt-einsum, opencv-contrib-python, networkx, imagesize, future, colorlog, chardet, pandas, modelscope, bce-python-sdk, paddlepaddle, aistudio-sdk, paddlex, paddleocr\r\n  Attempting uninstall: PyYAML\r\n    Found existing installation: PyYAML 6.0.3\r\n    Uninstalling PyYAML-6.0.3:\r\n      Successfully uninstalled PyYAML-6.0.3\r\n\r\nSuccessfully installed Pillow-12.1.1 PyYAML-6.0.2 aistudio-sdk-0.3.8 bce-python-sdk-0.9.60 chardet-6.0.0.post1 colorlog-6.10.1 future-1.0.0 imagesize-1.4.1 modelscope-1.34.0 networkx-3.6.1 opencv-contrib-python-4.10.0.84 opt-einsum-3.3.0 paddleocr-3.4.0 paddlepaddle-3.3.0 paddlex-3.4.2 pandas-3.0.1 prettytable-3.17.0 py-cpuinfo-9.0.0 pyclipper-1.4.0 pycryptodome-3.23.0 pypdfium2-5.5.0 python-bidi-0.6.7 safetensors-0.7.0 shapely-2.1.2 tzdata-2025.3 ujson-5.11.0\r\n","name":"pip install"},"isError":false,"timestamp":1772106476050}}
{"type":"message","id":"8c91d873","parentId":"2890dc84","timestamp":"2026-02-26T11:48:21.746Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"PaddleOCR 安装好了，现在需要创建 MCP 服务器的 Python 脚本文件。","thinkingSignature":"reasoning_content"},{"type":"text","text":"PaddleOCR 装好了。现在创建 MCP 服务器脚本：\n\n"},{"type":"toolCall","id":"call_b7fe21b4ea3440229344a720","name":"write","arguments":{"file_path":"D:\\.openclaw\\.openclaw\\workspace\\mcp-servers\\paddleocr-mcp\\server.py","content":"#!/usr/bin/env python3\n\"\"\"\nPaddleOCR MCP Server - 本地 OCR 图片识别\n\"\"\"\n\nimport sys\nimport base64\nfrom io import BytesIO\nfrom PIL import Image\nfrom paddleocr import PaddleOCR\n\nfrom mcp.server.fastmcp import FastMCP\n\nmcp = FastMCP(\"PaddleOCR\")\n\n# 初始化 PaddleOCR（中文 + 英文）\nocr = PaddleOCR(use_angle_cls=True, lang='ch', show_log=False)\n\n\n@mcp.tool()\ndef ocr_image(image_url: str = None, image_path: str = None, image_base64: str = None):\n    \"\"\"\n    使用 PaddleOCR 识别图片中的文字\n    \n    Args:\n        image_url: 图片 URL 地址\n        image_path: 本地图片路径\n        image_base64: 图片 base64 数据（可带 data:image/xxx;base64, 前缀）\n    \n    Returns:\n        识别结果：包含文字内容和置信度\n    \"\"\"\n    try:\n        img = None\n        \n        # 加载图片\n        if image_url:\n            import requests\n            response = requests.get(image_url, timeout=10)\n            response.raise_for_status()\n            img = Image.open(BytesIO(response.content))\n        elif image_path:\n            img = Image.open(image_path)\n        elif image_base64:\n            # 移除 data:image/xxx;base64, 前缀\n            if ',' in image_base64:\n                image_base64 = image_base64.split(',', 1)[1]\n            img_data = base64.b64decode(image_base64)\n            img = Image.open(BytesIO(img_data))\n        else:\n            return {\"error\": \"请提供 image_url、image_path 或 image_base64 之一\"}\n        \n        # 转换为 numpy 数组（PaddleOCR 需要 BGR 格式）\n        import numpy as np\n        img_array = np.array(img)\n        if len(img_array.shape) == 2:\n            img_array = np.stack([img_array] * 3, axis=-1)\n        if img_array.shape[-1] == 4:  # RGBA -> RGB\n            img_array = img_array[:, :, :3]\n        img_array = img_array[:, :, ::-1]  # RGB -> BGR\n        \n        # 执行 OCR\n        result = ocr.ocr(img_array, cls=True)\n        \n        # 解析结果\n        texts = []\n        if result and result[0]:\n            for line in result[0]:\n                bbox, (text, confidence) = line\n                texts.append({\n                    \"text\": text,\n                    \"confidence\": round(confidence, 4),\n                    \"bbox\": bbox\n                })\n        \n        return {\n            \"success\": True,\n            \"text_count\": len(texts),\n            \"full_text\": \"\\n\".join([t[\"text\"] for t in texts]),\n            \"details\": texts\n        }\n        \n    except Exception as e:\n        return {\"error\": str(e)}\n\n\nif __name__ == \"__main__\":\n    mcp.run()\n"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":109355,"output":814,"cacheRead":0,"cacheWrite":0,"totalTokens":110169,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772106476060}}
