{"type":"message","id":"2fde4f4f","parentId":"ddce1ea9","timestamp":"2026-02-26T07:44:37.755Z","message":{"role":"assistant","content":[{"type":"text","text":"成功了！但结果不太理想，看起来百度搜索的解析有问题。让我改进一下解析逻辑："},{"type":"toolCall","id":"functions.write:104","name":"write","arguments":{"file_path":"D:\\gooddog\\scripts\\mcp_ddgs_server.py","content":"#!/usr/bin/env python3\n\"\"\"\nMCP 服务器：多后端网页搜索（百度/搜狗优先 + ddgs auto + Bing 回退），供 OpenClaw/mcporter 调用。\n依赖: pip install mcp ddgs duckduckgo-search requests beautifulsoup4\n运行: python mcp_ddgs_server.py  （stdio，由 mcporter 启动）\n\"\"\"\nfrom __future__ import annotations\n\nimport sys\nimport json\nimport urllib.request\nimport urllib.parse\nfrom typing import List, Dict, Optional\n\n\ndef _search_baidu(query: str, max_results: int = 10) -> List[Dict]:\n    \"\"\"百度搜索 - 使用百度移动端，结构更简单\"\"\"\n    results = []\n    try:\n        # URL 编码查询词\n        encoded_query = urllib.parse.quote(query)\n        # 使用百度移动端，HTML 更简洁\n        url = f\"https://m.baidu.com/s?word={encoded_query}&pn=0\"\n        \n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (iPhone; CPU iPhone OS 14_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/14.0 Mobile/15A372 Safari/604.1\",\n            \"Accept\": \"text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8\",\n            \"Accept-Language\": \"zh-CN,zh;q=0.9\",\n        }\n        \n        req = urllib.request.Request(url, headers=headers)\n        with urllib.request.urlopen(req, timeout=15) as response:\n            html = response.read().decode('utf-8', errors='ignore')\n        \n        import re\n        \n        # 尝试多种百度结果模式\n        # 模式1: 标准搜索结果\n        result_blocks = re.findall(\n            r'<div[^>]*class=\"result\"[^>]*>.*?<a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a>.*?<span[^>]*class=\"(?:content-right|abstract)\"[^>]*>(.*?)</span>.*?</div>',\n            html, re.DOTALL\n        )\n        \n        if not result_blocks:\n            # 模式2: 移动端简化结构\n            result_blocks = re.findall(\n                r'<a[^>]*class=\"(?:title|t)\"[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a>.*?<div[^>]*class=\"(?:abstract|abs)\"[^>]*>(.*?)</div>',\n                html, re.DOTALL\n            )\n        \n        if not result_blocks:\n            # 模式3: 更宽松的匹配\n            result_blocks = re.findall(\n                r'<a[^>]*href=\"([^\"]*)\"[^>]*>\\s*<span[^>]*>(.*?)</span>.*?</a>.*?<div[^>]*>(.*?)</div>',\n                html, re.DOTALL\n            )[:max_results]\n        \n        for block in result_blocks[:max_results]:\n            href, title_html, body_html = block\n            \n            # 清理 HTML 标签\n            title = re.sub(r'<[^>]+>', '', title_html).strip()\n            body = re.sub(r'<[^>]+>', '', body_html).strip()\n            \n            # 处理相对链接\n            if href.startswith('/'):\n                href = 'https://m.baidu.com' + href\n            elif not href.startswith('http'):\n                href = 'https://m.baidu.com/' + href\n            \n            if title and len(title) > 5:  # 过滤无效结果\n                results.append({\n                    \"title\": title,\n                    \"href\": href,\n                    \"body\": body[:300] if body else \"\"\n                })\n        \n        return results\n    except Exception as e:\n        print(f\"百度搜索出错: {e}\", file=sys.stderr)\n        return []\n\n\ndef _search_sogou(query: str, max_results: int = 10) -> List[Dict]:\n    \"\"\"搜狗搜索 - 使用移动端\"\"\"\n    results = []\n    try:\n        encoded_query = urllib.parse.quote(query)\n        url = f\"https://m.sogou.com/web/searchList.jsp?keyword={encoded_query}\"\n        \n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (iPhone; CPU iPhone OS 14_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/14.0 Mobile/15A372 Safari/604.1\",\n            \"Accept\": \"text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8\",\n            \"Accept-Language\": \"zh-CN,zh;q=0.9\",\n        }\n        \n        req = urllib.request.Request(url, headers=headers)\n        with urllib.request.urlopen(req, timeout=15) as response:\n            html = response.read().decode('utf-8', errors='ignore')\n        \n        import re\n        \n        # 搜狗移动端结果解析\n        result_blocks = re.findall(\n            r'<div[^>]*class=\"(?:vrResult|result)\"[^>]*>.*?<h3[^>]*>.*?<a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a>.*?</h3>.*?<p[^>]*>(.*?)</p>.*?</div>',\n            html, re.DOTALL\n        )\n        \n        if not result_blocks:\n            # 备用模式\n            result_blocks = re.findall(\n                r'<a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)</a>.*?<div[^>]*class=\"str-text\"[^>]*>(.*?)</div>',\n                html, re.DOTALL\n            )[:max_results]\n        \n        for block in result_blocks[:max_results]:\n            href, title_html, body_html = block\n            \n            title = re.sub(r'<[^>]+>', '', title_html).strip()\n            body = re.sub(r'<[^>]+>', '', body_html).strip()\n            \n            if href.startswith('/'):\n                href = 'https://m.sogou.com' + href\n            \n            if title and len(title) > 5:\n                results.append({\n                    \"title\": title,\n                    \"href\": href"}}],"api":"openai-completions","provider":"bailian","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1772091735132,"errorMessage":"Request was aborted"}}
