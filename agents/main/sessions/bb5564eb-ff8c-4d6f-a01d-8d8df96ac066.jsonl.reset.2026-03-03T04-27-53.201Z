{"type":"message","id":"412e5d2f","parentId":"22b1d898","timestamp":"2026-03-03T04:00:41.645Z","message":{"role":"toolResult","toolCallId":"call_6d602141e1c74a938ca3fc24","toolName":"web_search","content":[{"type":"text","text":"{\n  \"error\": \"missing_brave_api_key\",\n  \"message\": \"web_search needs a Brave Search API key. Run `openclaw configure --section web` to store it, or set BRAVE_API_KEY in the Gateway environment.\",\n  \"docs\": \"https://docs.openclaw.ai/tools/web\"\n}"}],"details":{"error":"missing_brave_api_key","message":"web_search needs a Brave Search API key. Run `openclaw configure --section web` to store it, or set BRAVE_API_KEY in the Gateway environment.","docs":"https://docs.openclaw.ai/tools/web"},"isError":false,"timestamp":1772510441643}}
